# ── MySQL ─────────────────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=macmonitor
MYSQL_USER=monitor
MYSQL_PASSWORD=monitor123

# ── Collector (host → Docker MySQL) ───────────────────────────────────────
# The collector runs natively on macOS and connects to the MySQL container
# via the port exposed on localhost.
DB_HOST=127.0.0.1
DB_PORT=3307
DB_NAME=macmonitor
DB_USER=monitor
DB_PASSWORD=monitor123

# ── LLM ───────────────────────────────────────────────────────────────────
# Choose 'anthropic' or 'openai'
LLM_MODEL=claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-...
